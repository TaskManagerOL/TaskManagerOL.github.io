    <title>垃圾堆</title>
    <link href="http://example.com/2023/06/06/%E5%9E%83%E5%9C%BE%E5%A0%86/"/>
    <id>http://example.com/2023/06/06/%E5%9E%83%E5%9C%BE%E5%A0%86/</id>
